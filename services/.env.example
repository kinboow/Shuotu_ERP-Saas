# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=erp

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥
JWT_SECRET=your_jwt_secret_key

# 日志级别
LOG_LEVEL=info

# SHEIN平台配置（用于主动调用API）
SHEIN_APP_KEY=your_shein_app_key
SHEIN_APP_SECRET=your_shein_app_secret
SHEIN_BASE_URL=https://openapi.sheincorp.com

# SHEIN全托管Webhook配置（用于接收回调）
# 注意：Webhook验签使用appid和appSecretKey，而不是供应商的openKey+secretKey
SHEIN_FULL_APP_ID=your_app_id
SHEIN_FULL_APP_SECRET_KEY=your_app_secret_key

# TEMU平台配置
TEMU_CLIENT_ID=your_temu_client_id
TEMU_CLIENT_SECRET=your_temu_client_secret

# TikTok平台配置
TIKTOK_APP_KEY=your_tiktok_app_key
TIKTOK_APP_SECRET=your_tiktok_app_secret

# Webhook服务端口配置
WEBHOOK_HTTPS_PORT=8678
WEBHOOK_HTTP_PORT=8080

# SSL证书路径（可选，默认使用ssl目录下的证书）
# SSL_KEY_PATH=path/to/server.key
# SSL_CERT_PATH=path/to/server.crt
