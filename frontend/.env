# 前端环境变量配置

# API网关地址配置
# 使用相对路径，所有请求通过前端dev server代理转发到网关
# 这样无论局域网还是外网访问，都能正常请求后端
REACT_APP_API_URL=/api

# OSS服务地址（通过前端代理转发）
# 留空表示使用相对路径，通过setupProxy代理
REACT_APP_OSS_URL=

# 其他配置
REACT_APP_NAME=协途ERP

# HTTPS配置
PORT=3788
HTTPS=true
SSL_CRT_FILE=ssl/cert.pem
SSL_KEY_FILE=ssl/key.pem

HOST=0.0.0.0
DANGEROUSLY_DISABLE_HOST_CHECK=true
