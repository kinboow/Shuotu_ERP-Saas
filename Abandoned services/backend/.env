# ============================================================================
# 跨境电商ERP系统 - 环境配置模板
# ============================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写实际的配置值
# 3. 不要将 .env 文件提交到版本控制系统
# 
# 重要说明：
# - 所有平台的API配置（AppID、AppSecret等）都保存在数据库A的PlatformConfigs表中
# - 此配置文件只包含系统基础配置（数据库连接、JWT等）
# ============================================================================

# ============================================================================
# A数据库配置（ERP业务数据库）
# ============================================================================
DB_HOST=192.168.5.40
DB_PORT=3306
DB_USER=eer
DB_PASSWORD=wmRphLSZNsFbNeLk
DB_NAME=eer

# ============================================================================
# B数据库配置（认证数据库 - 用于登录验证）
# ============================================================================
AUTH_DB_HOST=192.168.5.40 
AUTH_DB_PORT=3306
AUTH_DB_USER=192_168_5_40
AUTH_DB_PASSWORD=BncDFe2GDcmMDzpn
AUTH_DB_NAME=192_168_5_40

# ============================================================================
# 服务器配置
# ============================================================================
PORT=5000

# ============================================================================
# JWT配置（用于用户认证）
# ============================================================================
# 生成随机密钥方法：
# Node.js: require('crypto').randomBytes(64).toString('hex')
# 在线工具: https://randomkeygen.com/
JWT_SECRET=                     # ← 填写随机生成的密钥（至少32位）
JWT_EXPIRES_IN=7d               # Token有效期（7天）

# ============================================================================
# 平台API配置说明
# ============================================================================
# 
# ⚠️ 重要：所有平台的API配置都保存在数据库中，不在此文件配置！
# 
# 平台API配置位置：
# - 数据库：cross_border_erp
# - 表名：PlatformConfigs
# - 包含字段：
#   * platform_name: 平台名称（shein_full, amazon, ebay等）
#   * app_id: 应用ID/AppID
#   * app_secret: 应用密钥/AppSecret
#   * callback_url: 回调地址
#   * api_domain: API域名
#   * config_data: 其他配置信息（JSON格式）
# 
# 配置方法：
# 1. 方式一：运行初始化脚本
#    cd backend
#    npm run init-platform
# 
# 2. 方式二：直接在数据库中插入/更新
#    INSERT INTO PlatformConfigs (platform_name, app_id, app_secret, ...) VALUES (...);
# 
# 3. 方式三：通过管理界面配置（如果已开发）
# 
# 支持的平台：
# - SHEIN(全托管): shein_full
# - SHEIN(半托管): shein_semi
# - Amazon: amazon
# - eBay: ebay
# 
# ============================================================================

# ============================================================================
# 配置完成检查清单
# ============================================================================
# [ ] A数据库连接信息已填写
# [ ] B数据库连接信息已填写
# [ ] JWT_SECRET已生成并填写
# [ ] 文件已保存为 .env
# [ ] 已测试数据库连接
# [ ] 已在数据库中配置平台API信息（运行 npm run init-platform）
